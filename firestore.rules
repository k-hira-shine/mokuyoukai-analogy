rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 許可するメールアドレスのリスト
    function isAllowed() {
      return request.auth != null &&
        request.auth.token.email in [
          'kazuya.imasaka@gmail.com'
          // ビジネスパートナーのメールアドレスをここに追加:
          // 'partner@example.com'
        ];
    }

    // 管理者（書き込み権限あり）
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'kazuya.imasaka@gmail.com';
    }

    // 認証一時停止中: 全員読み書き可（テスト用）
    match /episodes/{docId} {
      allow read, write: if true;
    }

    match /contents/{docId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, write: if true;
    }

    match /lectures/{docId} {
      allow read, write: if true;
    }
  }
}
